# AI triage provider adapter. Use "mock" until a BAA/DPA-approved provider is configured.
AI_TRIAGE_PROVIDER=mock
AI_TRIAGE_API_KEY=

# Optional product configuration.
NEXT_PUBLIC_APP_URL=http://localhost:3000
PSYCHU_SUPPORT_EMAIL=support@psychu.test
PSYCHU_SECURITY_EMAIL=security@psychu.test
